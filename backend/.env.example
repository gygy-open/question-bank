# 本地开发环境示例
# 生产环境请复制根目录 .env.example，并通过 docker-compose 加载

# JWT 签名密钥，生产环境必须替换
# 生成命令: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

LOG_LEVEL=INFO

# 数据库连接串
DB_URL=mysql+aiomysql://question_bank:change-me@localhost:3306/question_bank

# ChromaDB
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
