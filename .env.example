# ========== 应用密钥 ==========
# 用于 JWT 签名，生产环境必须替换为随机字符串
# 生成命令: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

# ========== 数据库 ==========
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=question_bank
MYSQL_USER=question_bank
MYSQL_PASSWORD=change-me

# 后端连接串 (docker-compose 环境使用 mysql 主机名)
DB_URL=mysql+aiomysql://question_bank:change-me@mysql:3306/question_bank

# ========== ChromaDB ==========
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ========== 其它 ==========
LOG_LEVEL=INFO

# 容器内用户/组 ID (Linux 下建议设为 `id -u` / `id -g`)
UID=1000
GID=1000
