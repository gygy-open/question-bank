server {
    listen 80;
    server_name _;

    # 设置客户端请求体大小限制
    client_max_body_size 100M;

    # 🔧 关键修复: 使用相对重定向,避免协议问题
    # 当 nginx 自动添加尾部斜杠重定向时,使用相对路径而不是绝对 URL
    absolute_redirect off;
    
    # 检测真实协议(处理位于 HTTPS 负载均衡器后的情况)
    # 如果上游代理设置了 X-Forwarded-Proto,则使用该值
    set $real_scheme $scheme;
    if ($http_x_forwarded_proto = 'https') {
        set $real_scheme https;
    }

    root /usr/share/nginx/html;

    # 后端 API 反向代理
    location /api {
        proxy_pass ${API_BASE_URL}/api;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        # 使用检测到的真实协议
        proxy_set_header X-Forwarded-Proto $real_scheme;
        proxy_cache_bypass $http_upgrade;
        
        # LLM Stream 超时配置
        # 连接超时：建立连接的最大时间
        proxy_connect_timeout 60s;
        # 发送超时：向后端发送请求的最大时间
        proxy_send_timeout 60s;
        # 读取超时：从后端读取响应的最大时间（对于 stream 很重要）
        # 设置为 10 分钟，适合 LLM 长时间流式响应
        proxy_read_timeout 600s;
        # 禁用缓冲，确保流式响应实时传输
        proxy_buffering off;
        # 保持连接
        proxy_http_version 1.1;
    }

    # 静态文件反向代理
    location ^~ /static {
        proxy_pass ${API_BASE_URL}/static;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $real_scheme;
    }

    location ^~ /uploads {
        proxy_pass ${API_BASE_URL}/uploads;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $real_scheme;
    }

    # 服务工作者 - 确保不被缓存且正确提供
    location = /sw.js {
        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0";
        add_header Service-Worker-Allowed "/";
        types {
            application/javascript js;
        }
        try_files $uri =404;
    }

    location = /manifest.webmanifest {
        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0";
        types {
            application/manifest+json webmanifest;
        }
        try_files $uri =404;
    }

    # 静态资源
    location ~* \.(?:ico|css|js|png|jpg|jpeg|svg|woff|woff2|ttf|eot|gif)$ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        expires 1y;
        access_log off;
    }

    # Nuxt 页面路由（SPA 回退）
    location / {
        try_files $uri $uri/ /200.html; # 回退到 index.html 处理 SPA 路由
    }

    # 安全头（推荐用于 HTTPS）
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
}
